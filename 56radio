<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vice Frequency — Hero Mockup</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300..900&family=Manrope:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap');

  :root {
    --bg: #0D0518;
    --coral: #FF6B47;
    --purple: #7B2FF7;
    --cyan: #00E5FF;
    --magenta: #FF2E9A;
    --text: #F2EEFB;
    --text-dim: #a89bc4;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; }
  }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Manrope', sans-serif;
    overflow-x: hidden;
  }

  nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(13,5,24,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(123,47,247,0.3);
    padding: 14px 20px;
  }
  .nav-row { display: flex; align-items: center; justify-content: space-between; }
  .logo { font-family: 'Fraunces', serif; font-weight: 700; font-size: 1.1rem; letter-spacing: 0.02em; }
  .logo span { color: var(--coral); }
  .waveform {
    flex: 1; height: 28px; margin: 0 16px;
    display: flex; align-items: center; gap: 2px; overflow: hidden;
  }
  .wave-bar {
    width: 3px; background: linear-gradient(180deg, var(--cyan), var(--magenta));
    border-radius: 2px; animation: pulse 1.2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { height: 4px; opacity: 0.4; }
    50% { height: 22px; opacity: 1; }
  }

  .hero {
    min-height: 92vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 40px 20px;
    position: relative;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(255,46,154,0.18), transparent 60%),
      radial-gradient(ellipse 60% 40% at 20% 100%, rgba(0,229,255,0.12), transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(255,107,71,0.12), transparent 60%),
      var(--bg);
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem; letter-spacing: 0.15em; color: var(--cyan);
    text-transform: uppercase; margin-bottom: 18px;
    opacity: 0; animation: fadeUp 0.8s ease-out 0.1s forwards;
  }
  h1 {
    font-family: 'Fraunces', serif; font-weight: 600; font-size: clamp(2.4rem, 9vw, 4.5rem);
    line-height: 1.02; letter-spacing: -0.01em;
    background: linear-gradient(100deg, var(--coral) 10%, var(--magenta) 45%, var(--cyan) 90%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    opacity: 0; animation: fadeUp 0.9s ease-out 0.25s forwards;
  }
  .hero-sub {
    color: var(--text-dim); font-size: 1.02rem; max-width: 480px; margin: 18px auto 0;
    opacity: 0; animation: fadeUp 0.9s ease-out 0.4s forwards;
  }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

  .countdown {
    display: flex; gap: 18px; margin-top: 40px;
    opacity: 0; animation: fadeUp 0.9s ease-out 0.55s forwards;
  }
  .count-unit { text-align: center; }
  .count-num {
    font-family: 'JetBrains Mono', monospace; font-weight: 700;
    font-size: clamp(1.6rem, 5vw, 2.4rem); color: var(--text);
  }
  .count-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
    color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px;
  }

  .radio-section { padding: 70px 20px 90px; max-width: 480px; margin: 0 auto; }
  .radio-title {
    font-family: 'Fraunces', serif; font-size: 1.4rem; text-align: center; margin-bottom: 6px;
  }
  .radio-sub { text-align: center; color: var(--text-dim); font-size: 0.85rem; margin-bottom: 28px; }

  .radio-unit {
    border: 3px solid #1a0f2e;
    border-radius: 10px;
    background: linear-gradient(155deg, #241634 0%, #150a24 100%);
    padding: 18px; position: relative; overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .radio-unit::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(255,255,255,0.015) 2px, rgba(255,255,255,0.015) 3px);
    pointer-events: none;
  }

  .lcd-screen {
    background: #0a1810;
    border-radius: 5px;
    border: 2px solid #050c08;
    padding: 14px 16px;
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.7);
    position: relative; margin-bottom: 14px;
  }
  .lcd-freq {
    font-family: 'JetBrains Mono', monospace; font-weight: 700;
    font-size: 1.9rem; letter-spacing: 0.06em;
    color: #4dffb8;
    text-shadow: 0 0 4px #4dffb8, 0 0 12px rgba(77,255,184,0.5);
  }
  .lcd-sub {
    font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
    color: #3ad69e; opacity: 0.85; letter-spacing: 0.08em; margin-top: 4px;
    min-height: 1.4em;
  }
  .on-air {
    position: absolute; top: 12px; right: 12px;
    font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; font-weight: 700;
    padding: 3px 8px; border-radius: 3px; letter-spacing: 0.05em;
    background: rgba(90,90,90,0.3); color: var(--text-dim);
    transition: all 0.3s ease;
  }
  .on-air.live { background: var(--magenta); color: #fff; animation: blink 1s ease-in-out infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.55; } }

  .track-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 2px; min-height: 1.3em; color: var(--text); }
  .dj-caption {
    font-size: 0.8rem; color: var(--text-dim); font-style: italic;
    min-height: 2.2em; margin: 8px 0 4px; line-height: 1.4;
    border-left: 2px solid var(--magenta); padding-left: 10px;
    opacity: 0; transition: opacity 0.3s ease;
  }
  .dj-caption.show { opacity: 1; }

  .eq {
    display: flex; align-items: flex-end; gap: 3px; height: 34px; margin: 12px 0 16px;
  }
  .eq-bar {
    flex: 1; background: linear-gradient(180deg, var(--cyan), var(--purple));
    border-radius: 2px 2px 0 0; transition: height 0.15s ease;
  }

  .preset-panel { display: grid; grid-template-columns: repeat(6, 1fr); gap: 7px; }
  .preset-btn {
    aspect-ratio: 1;
    background: linear-gradient(180deg, #3a2a52 0%, #241634 55%, #1a0f2e 100%);
    border: none; border-radius: 6px;
    box-shadow: 0 3px 0 #0d0518, 0 4px 6px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.12);
    color: var(--text-dim); font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; font-weight: 700;
    cursor: pointer; transition: all 0.08s ease;
    display: flex; align-items: center; justify-content: center;
  }
  .preset-btn:active { transform: translateY(2px); box-shadow: 0 1px 0 #0d0518, inset 0 1px 0 rgba(255,255,255,0.12); }
  .preset-btn.active { color: var(--cyan); box-shadow: 0 3px 0 #0d0518, 0 0 10px rgba(0,229,255,0.4), inset 0 1px 0 rgba(255,255,255,0.12); }
  .preset-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .preset-label { font-size: 0.6rem; text-align: center; margin-top: 8px; color: var(--text-dim); letter-spacing: 0.05em; }

  .start-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(13,5,24,0.92); backdrop-filter: blur(6px);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; text-align: center; padding: 20px;
  }
  .start-overlay .btn {
    font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 0.85rem;
    letter-spacing: 0.08em; padding: 16px 32px; border-radius: 40px;
    background: linear-gradient(90deg, var(--coral), var(--magenta));
    color: #fff; border: none; margin-bottom: 14px;
  }
  .start-overlay p { color: var(--text-dim); font-size: 0.8rem; max-width: 320px; }

  .note {
    max-width: 480px; margin: 0 auto; padding: 0 20px 60px;
    color: var(--text-dim); font-size: 0.78rem; text-align: center; line-height: 1.5;
  }
</style>
</head>
<body>

<div class="start-overlay" id="startOverlay">